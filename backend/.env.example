# Database
DATABASE_URL="mysql://root:password@localhost:3306/worktrack"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=development

# Payroll: exclude_sundays (default) | fixed_26
PAYROLL_WORKING_DAYS_MODE=exclude_sundays

# Email (SMTP) — leave blank to disable email notifications
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-email-password
